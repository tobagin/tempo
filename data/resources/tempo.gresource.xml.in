<?xml version="1.0" encoding="UTF-8"?>
<gresources>
  <gresource prefix="@RESOURCE_PATH@">
    <!-- UI Files -->
    <file preprocess="xml-stripblanks" alias="ui/main_window.ui">main_window.ui</file>
    <file preprocess="xml-stripblanks" alias="ui/preferences_dialog.ui">preferences_dialog.ui</file>
    <file preprocess="xml-stripblanks" alias="ui/keyboard_shortcuts_dialog.ui">keyboard_shortcuts_dialog.ui</file>
    <file preprocess="xml-stripblanks" alias="preset_manager_dialog.ui">preset_manager_dialog.ui</file>

    <!-- Audio Files -->
    <file>sounds/high.wav</file>
    <file>sounds/low.wav</file>
    <file>sounds/woodblock-high.wav</file>
    <file>sounds/woodblock-low.wav</file>
    <file>sounds/metal-high.wav</file>
    <file>sounds/metal-low.wav</file>
    <file>sounds/digital-high.wav</file>
    <file>sounds/digital-low.wav</file>

    <!-- Rhythm Patterns -->
    <file>patterns/son-clave-32.json</file>
    <file>patterns/son-clave-23.json</file>
    <file>patterns/rumba-clave.json</file>
    <file>patterns/bossa-nova.json</file>
    <file>patterns/swing-ride.json</file>
    <file>patterns/backbeat.json</file>

    <!-- CSS Styles -->
    <file>style.css</file>
  </gresource>
</gresources>